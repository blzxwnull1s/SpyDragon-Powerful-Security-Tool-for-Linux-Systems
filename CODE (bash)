tag() {
    local t="$1" color="${2:-$GREEN}"
    printf "${color}[${t}]${RESET}"
}

print_result_line() {
    local line="$1"
    case "$line" in
        \[\+\]*|✓*)   cl "$GREEN"   "$line" ;;
        \[\-\]*|\[!\]*|✗*) cl "$RED" "$line" ;;
        \[\*\]*|\[~\]*) cl "$CYAN"  "$line" ;;
        \[\>\]*|→*|▶*) cl "$YELLOW" "$line" ;;
        ═*|─*|╔*|╗*|╚*|╝*|║*) cl "$DGREEN" "$line" ;;
        \#*|==*)        cl "$MAGENTA" "$line" ;;
        "")             echo "" ;;
        *)              cl "$WHITE" "$line" ;;
    esac
}

spinner() {
    local msg="$1"
    local frames=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
    local msgs=(
        "Conectando con base de datos OSINT"
        "Analizando objetivo"
        "Recopilando inteligencia"
        "Procesando resultados"
        "Compilando informe"
    )
    local i=0 elapsed=0 pct=0
    local start=$SECONDS

    while kill -0 "$BGPID" 2>/dev/null; do
        elapsed=$(( SECONDS - start ))
        local midx=$(( elapsed / 2 ))
        [[ $midx -ge ${#msgs[@]} ]] && midx=$(( ${#msgs[@]} - 1 ))
        local cmsg="${msgs[$midx]}"
        pct=$(( elapsed * 8 ))
        [[ $pct -gt 95 ]] && pct=95
        local filled=$(( pct / 5 ))
        local empty=$(( 20 - filled ))
        local bar
        bar="$(printf '█%.0s' $(seq 1 $filled 2>/dev/null))$(printf '░%.0s' $(seq 1 $empty 2>/dev/null))"
        printf "\r  ${GREEN}${frames[$((i % ${#frames[@]}))]}${RESET}  ${DGREEN}${cmsg}...${RESET}  ${GREEN}[${bar}]${RESET} ${YELLOW}${pct}%%${RESET}   "
        sleep 0.1
        (( i++ ))
    done
    printf "\r  ${GREEN}✔${RESET}  ${DGREEN}Análisis completado.${RESET}%40s\n" ""
}

typewrite() {
    local text="$1" color="${2:-$GREEN}" delay="${3:-0.012}"
    local i=0
    while [[ $i -lt ${#text} ]]; do
        printf "${color}${text:$i:1}${RESET}"
        sleep "$delay"
        (( i++ ))
    done
    echo
}

